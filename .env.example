# Скопируй в .env и подставь свои значения:  cp .env.example .env
# Файл .env НЕ коммить в git — в нём токен от аккаунта.

# Токен владельца плейлиста (получить: python get_token.py)
YM_TOKEN=

# Плейлист (UUID, полный URL или числовой kind).
# Если не задать — используется значение по умолчанию из docker-compose.yml.
YM_PLAYLIST=
