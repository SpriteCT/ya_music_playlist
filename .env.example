# Скопируй в .env и подставь свои значения:  cp .env.example .env
# Файл .env НЕ коммить в git — в нём секрет сессий (а через него, косвенно,
# доступ к токенам всех залогинившихся пользователей).

# Ключ для подписи сессионных cookie. Сгенерировать:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Без него сессии всех пользователей слетают при каждом перезапуске процесса.
FLASK_SECRET_KEY=

# Поставь 1, когда сервис стоит за HTTPS-прокси (nginx/Caddy) — тогда cookie
# сессии получит флаг Secure. На голом http (локальная проверка) оставь
# пустым/0 — иначе браузер cookie не примет и логин не сохранится.
SESSION_COOKIE_SECURE=
