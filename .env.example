# Скопируй в .env и подставь свои значения:  cp .env.example .env
# Файл .env НЕ коммить в git — в нём токен от аккаунта.

# Пароль для входа в админку (/admin) — там логин в Я.Музыку через Яндекс
# и создание ссылок для сбора треков. Обязателен, без него /admin отключена.
ADMIN_PASSWORD=

# Ключ для подписи сессионных cookie админки. Сгенерировать:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Без него сессии слетают при каждом перезапуске процесса.
FLASK_SECRET_KEY=

# Поставь 1, когда сервис стоит за HTTPS-прокси (nginx/Caddy) — тогда cookie
# сессии админки получит флаг Secure. На голом http (локальная проверка)
# оставь пустым/0 — иначе браузер cookie не примет и логин не сохранится.
SESSION_COOKIE_SECURE=

# Необязательный legacy-бутстрап — если не хочется логиниться через /admin
# в браузере, можно один раз получить токен вручную (python get_token.py)
# и вписать сюда. Плейлист всё равно назначается только через ссылки в
# /admin — без хотя бы одной ссылки публичной формы не будет.
YM_TOKEN=

# Плейлист по умолчанию для legacy-бутстрапа (необязательно).
YM_PLAYLIST=
